{
  "name": "health-app-mvp",
  "version": "0.1.0",
  "description": "Health management app MVP - Backend + Frontend",
  "type": "module",
  "private": true,
  "scripts": {
    "install-all": "npm install && cd frontend && npm install",
    "dev": "concurrently \"npm run dev:backend\" \"npm run dev:frontend\"",
    "dev:backend": "node server.js",
    "dev:frontend": "cd frontend && npm run dev",
    "init-db": "python3 init_db.py",
    "setup": "npm run install-all && npm run init-db",
    "build": "cd frontend && npm run build"
  },
  "dependencies": {
    "express": "^4.18.2",
    "sqlite3": "^5.1.6",
    "cors": "^2.8.5"
  },
  "devDependencies": {
    "concurrently": "^8.0.0"
  }
}
